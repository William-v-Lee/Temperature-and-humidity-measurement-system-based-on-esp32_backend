.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
}

.subtitle {
  font-size: 24rpx;
  color: #9ca3af;
}

.btn-refresh {
  padding: 8rpx 28rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  background: rgba(148, 163, 184, 0.2);
  color: #e5e7eb;
  border: none;
}

.list {
  max-height: calc(100vh - 140rpx);
}

.device-item {
  margin-bottom: 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.9);
  border: 1rpx solid rgba(148, 163, 184, 0.3);
}

.device-name {
  font-size: 30rpx;
  font-weight: 550;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.device-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.mono {
  font-family: monospace;
}

.sep {
  opacity: 0.7;
}

.empty {
  margin-top: 60rpx;
  text-align: center;
  color: #6b7280;
}

.error-banner {
  margin-bottom: 16rpx;
  padding: 10rpx 18rpx;
  border-radius: 9999rpx;
  background: rgba(248, 113, 113, 0.95);
  color: #111827;
  font-size: 24rpx;
}
