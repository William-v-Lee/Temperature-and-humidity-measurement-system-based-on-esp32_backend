<view class="page">
  <view class="header">
    <view class="title-wrap">
      <text class="title">设备列表</text>
      <text class="subtitle">选择一个设备进入详情页</text>
    </view>
    <button class="btn-refresh" loading="{{loading}}" bindtap="loadDevices">
      {{ loading ? '刷新中...' : '刷新' }}
    </button>
  </view>

  <view wx:if="{{error}}" class="error-banner">
    {{error}}
  </view>

  <scroll-view class="list" scroll-y="true">
    <block wx:if="{{devices.length}}">
      <view
        wx:for="{{devices}}"
        wx:key="{{item.id || item.deviceId}}"
        class="device-item"
        data-device-id="{{item.deviceId}}"
        bindtap="handleTapDevice"
      >
        <view class="device-name">
          {{ item.name || item.deviceId }}
        </view>
        <view class="device-meta">
          <text class="mono">{{ item.deviceId }}</text>
          <text class="sep">·</text>
          <text>{{ item.location || '未知位置' }}</text>
        </view>
      </view>
    </block>

    <view wx:else class="empty">
      暂无设备
    </view>
  </scroll-view>
</view>
